PORT=5184
CLIENT_ORIGIN=http://localhost:5183
DATA_DIR=server/data
FFMPEG_PATH=

# Server only. Do not put API keys in frontend files.
MODEL_PROVIDER=openai-compatible
MODEL_API_KEY=
MODEL_BASE_URL=https://yunwu.ai/v1
MODEL_NAME=gpt-4o-mini
MODEL_MAX_TOKENS=12000

# Render free plan is better for small test videos.
MAX_UPLOAD_MB=250

# Optional fallback for public video pages. Keep false unless you install yt-dlp.
YTDLP_ENABLED=true
YTDLP_PYTHON=python

# Frontend only. Set this in Vercel after Render backend is deployed.
VITE_API_BASE_URL=https://your-render-service.onrender.com
